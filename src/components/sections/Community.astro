---
import CornerBorders from "../ui/CornerBorders.astro";
import type { Translation } from "../../i18n";

interface Props {
  t: Translation["community"];
}

const { t } = Astro.props as Props;
---

<section class="mt-[160px] lg:mt-[200px]">
  <div class="max-w-[1728px] w-full px-[3%] lg:px-[5%]">
    <div
      class="community-card relative overflow-hidden border border-white/12 bg-[#0F1419] px-8 py-14 md:px-16 md:py-16"
    >
      <CornerBorders color="#07D9C4" />
      <span
        class="pointer-events-none absolute inset-x-0 top-0 h-px opacity-60 bg-gradient-to-r from-transparent via-[#07D9C4]/40 to-transparent"
        aria-hidden="true"></span>
      <span
        class="pointer-events-none absolute inset-x-0 bottom-0 h-px opacity-40 bg-gradient-to-r from-transparent via-white/10 to-transparent"
        aria-hidden="true"></span>

      <div
        class="flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between"
      >
        <div class="max-w-[700px] space-y-6">
          <div class="space-y-3">
            <span
              class="text-sm font-semibold uppercase tracking-[0.35em] text-primary/80"
            >
              {t.badge}
            </span>
            <h3
              class="text-[36px] leading-[42px] font-bold md:text-[48px] md:leading-[54px]"
            >
              {t.title}
            </h3>
            <p class="text-base leading-7 text-white/75">{t.description}</p>
          </div>

          <ul class="flex flex-wrap gap-3">
            {t.highlights.map((item) => <li class="community-pill">{item}</li>)}
          </ul>
        </div>

        <div class="flex flex-col items-center gap-4 text-center lg:items-end">
          <span class="text-white/60 text-sm uppercase tracking-[0.25em]"
            >{t.ctaTagline}</span
          >
          <a
            onclick="trackClick('comunity-sec7')"
            href="https://t.me/vallax_group"
            target="_blank"
            class="btn btn-primary !w-fit px-[30px] py-[26px] group"
          >
            <span
              class="text-[#07D9C4] text-[28px] font-semibold leading-[20px]"
              >/</span
            >
            <span class="text-[#07D9C4] text-lg font-bold leading-[20px]"
              >{t.ctaLabel}</span
            >

            <CornerBorders color="#07D9C4" />
          </a>
          <p class="text-xs leading-5 text-white/45 max-w-[220px]">
            {t.finePrint}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
