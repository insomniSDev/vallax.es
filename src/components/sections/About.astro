---
import { Image } from "astro:assets";
import VallaxLogoLetters from "../../images/logo-letters.png";
import CornerBorders from "../ui/CornerBorders.astro";
import PlusIcon from "../icons/PlusIcon.astro";
import type { Translation } from "../../i18n";

interface Props {
  t: Translation["about"];
}

const { t } = Astro.props as Props;
---

<div class="mt-10 md:mt-[100px] lg:mt-[132px]" id="que-es-vallax">
  <section class="linear-bg-aux-3 border border-white/15 px-6 py-12 md:px-12 md:py-16">
    <div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:gap-12">
      <div class="flex flex-col gap-6 lg:w-3/5">
        <span class="uppercase text-sm font-semibold tracking-[0.3em] text-primary/80">
          {t.badge}
        </span>
        <h3 class="text-[34px] leading-9 font-bold md:text-[48px] md:leading-[54px]">
          {t.title}
        </h3>
        <p class="text-base leading-7 text-white/80 md:text-lg md:leading-8" innerHTML={t.description}></p>

        <ul class="space-y-5">
          {t.features.map((feature) => (
            <li class="flex items-start gap-4" key={feature.title}>
              <span class="flex-none mt-1 text-primary">
                <PlusIcon size={18} opacity={1} stroke="#07D9C4" />
              </span>
              <div>
                <p class="text-lg font-semibold leading-6">{feature.title}</p>
                <p class="mt-1 text-base leading-6 text-white/70">{feature.description}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div class="flex flex-col gap-6 lg:w-2/5">
        <div class="relative group border border-primary/40 bg-primary/5 p-6 md:p-8">
          <CornerBorders color="#07D9C4" />
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-primary/80">
            {t.highlightBadge}
          </p>
          <h4 class="mt-3 text-2xl font-bold leading-8 text-primary md:text-3xl md:leading-9">
            {t.highlightTitle}
          </h4>
          <p class="mt-3 text-base leading-6 text-white/70">{t.highlightDescription}</p>
          <dl class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
            {t.stats.map((stat) => (
              <div class="flex flex-col" key={`${stat.value}-${stat.label}`}>
                <dt class="text-3xl font-semibold text-white">{stat.value}</dt>
                <dd class="text-sm leading-5 text-white/60">{stat.label}</dd>
              </div>
            ))}
          </dl>
        </div>

        <div class="flex items-center gap-4 border border-white/10 bg-white/5 px-5 py-4">
          <Image src={VallaxLogoLetters} alt="Vallax" class="w-24" />
          <p class="text-base leading-6 text-white/70">{t.communityCallout}</p>
        </div>
      </div>
    </div>
  </section>
</div>
