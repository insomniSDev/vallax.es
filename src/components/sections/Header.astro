---
import PlusIcon from "../icons/PlusIcon.astro";
import CornerBorders from "../ui/CornerBorders.astro";
import type { Translation } from "../../i18n";

interface Props {
  t: Translation["hero"];
}

const { t } = Astro.props as Props;
---

<section class="max-w-[1728px] w-full pt-28 pb-18">
  <div class="px-[3%] lg:px-[5%]">
    <div
      class="mx-auto grid max-w-[1080px] gap-12 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]"
    >
      <div class="space-y-6 text-left">
        <span
          class="inline-flex items-center gap-2 border border-primary/40 bg-primary/10 px-4 py-1 text-xs font-semibold uppercase tracking-[0.35em] text-primary"
        >
          {t.badge}
        </span>

        <div class="space-y-3">
          <h1
            class="text-[32px] leading-[44px] font-extrabold md:text-[48px] md:leading-[54px]"
          >
            {t.title}
          </h1>
          <p
            class="text-sm leading-6 text-white/65 md:text-base md:leading-7 max-w-[520px]"
          >
            {t.description}
          </p>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-4">
          <a
            onclick="trackClick('hero-primary-cta-alt')"
            href="https://t.me/vallaxbot"
            target="_blank"
            class="btn btn-primary px-[32px] py-[22px] group"
          >
            <span
              class="text-[#07D9C4] text-[32px] font-semibold leading-[20px]"
              >/</span
            >
            <span class="text-[#07D9C4] text-lg font-bold leading-[20px]"
              >{t.primaryCta}</span
            >
            <CornerBorders color="#07D9C4" />
          </a>

          <a
            onclick="trackClick('hero-secondary-cta-alt')"
            href="https://t.me/vallax_group"
            target="_blank"
            class="inline-flex items-center gap-2 border border-white/20 px-4 py-3 text-xs uppercase tracking-[0.3em] text-white/70 transition-colors hover:text-white"
          >
            <PlusIcon
              size={14}
              stroke="#FFFFFF"
              opacity={0.8}
              strokeWidth={1.5}
            />
            {t.communityCta}
          </a>
        </div>

        <ul class="grid gap-2 text-sm text-white/60">
          {
            t.bulletPoints.map((bullet) => (
              <li class="flex items-start gap-2">
                <span class="mt-1 text-primary">
                  <PlusIcon
                    size={12}
                    stroke="#07D9C4"
                    opacity={1}
                    strokeWidth={1.5}
                  />
                </span>
                {bullet}
              </li>
            ))
          }
        </ul>
      </div>

      <aside class="space-y-5 text-left text-sm leading-6 text-white/65">
        <div class="relative border border-white/15 bg-black/45 px-6 py-6">
          <CornerBorders color="#07D9C4" />
          <p class="text-xs uppercase tracking-[0.3em] text-white/50">
            {t.asideTitle}
          </p>
          <ol class="mt-4 space-y-3 text-white/70">
            {
              t.steps.map((step, index) => (
                <li class="flex items-start gap-3">
                  <span class="text-primary text-sm font-semibold">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <span>{step}</span>
                </li>
              ))
            }
          </ol>
        </div>

        <div
          class="flex flex-col gap-3 border border-white/10 bg-white/5 px-5 py-4 text-xs uppercase tracking-[0.25em] text-white/55"
        >
          {t.monitorLines.map((line) => <p class="text-white/70">{line}</p>)}
        </div>
      </aside>
    </div>
  </div>
</section>
