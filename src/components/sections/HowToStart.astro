---
import CornerBorders from "../ui/CornerBorders.astro";
import type { Translation } from "../../i18n";

interface Props {
  t: Translation["howToStart"];
}

const { t } = Astro.props as Props;
---

<div id="howitworks"></div>
<section class="mt-[160px] lg:mt-[200px]">
  <div class="max-w-[1728px] w-full">
    <div class="px-[3%] lg:px-[5%]">
      <div class="space-y-10 text-center md:text-left">
        <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <span class="text-sm font-semibold uppercase tracking-[0.35em] text-primary/80">
              {t.badge}
            </span>
            <h3 class="mt-2 text-[34px] leading-9 font-bold md:text-[48px] md:leading-[54px]">
              {t.title}
            </h3>
          </div>
          <p class="text-base leading-6 text-white/70 md:max-w-[460px]">{t.description}</p>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
          {t.steps.map((step) => (
            <article
              class="how-step group relative overflow-hidden border border-white/15 linear-bg-aux-5 p-7 md:p-9 flex flex-col gap-6 text-left"
              key={step.number}
            >
              <CornerBorders color="#07D9C4" />
              <span
                class="pointer-events-none absolute inset-x-0 top-0 h-px opacity-60 bg-gradient-to-r from-transparent via-[#07D9C4]/40 to-transparent"
                aria-hidden="true"
              ></span>
              <span
                class="pointer-events-none absolute inset-x-0 bottom-0 h-px opacity-40 bg-gradient-to-r from-transparent via-white/10 to-transparent"
                aria-hidden="true"
              ></span>

              <header class="flex items-start gap-4">
                <span class="step-index">{step.number}</span>
                <div class="space-y-3">
                  <h4 class="text-[22px] font-bold leading-7 text-white md:text-[26px] md:leading-8">
                    {step.title}
                  </h4>
                  <p class="text-base leading-7 text-white/75">{step.description}</p>
                </div>
              </header>

              {step.hint && (
                <p class="border border-[#07D9C4]/25 bg-primary/10 px-4 py-3 text-sm leading-5 text-[#07D9C4]/90">
                  {step.hint}
                </p>
              )}

              {step.ctaLabel && (
                <div class="flex justify-start">
                  <a
                    onclick="trackClick('vallax-sec5')"
                    href="https://t.me/vallaxbot"
                    target="_blank"
                    class="btn btn-primary !w-fit px-[26px] py-[22px] group"
                  >
                    <span class="text-[#07D9C4] text-[24px] font-semibold leading-[20px]">/</span>
                    <span class="text-[#07D9C4] text-lg font-bold leading-[20px]">
                      {step.ctaLabel}
                    </span>

                    <CornerBorders color="#07D9C4" />
                  </a>
                </div>
              )}
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
