---
import Image from "astro/components/Image.astro";
import Logo from "../../images/logo.png";
import CornerBorders from "../ui/CornerBorders.astro";
import type { Translation, Locale } from "../../i18n";

interface Props {
  t: Translation["navbar"];
  lang: Locale;
}

const { t, lang } = Astro.props as Props;

const links = [
  { href: "#howitworks", label: t.links.howItWorks },
  { href: "#que-es-vallax", label: t.links.whatIs },
  {
    href: "https://t.me/vallax_group",
    label: t.links.community,
    external: true,
  },
];
---

<nav
  class="fixed top-0 left-0 z-50 w-full border-b border-white/10 bg-black/50 backdrop-blur-xl"
>
  <div
    class="mx-auto flex max-w-[1728px] items-center justify-between gap-6 px-[3%] py-4 lg:px-[5%]"
  >
    <a href={lang === "es" ? "/es/" : "/en/"} class="flex items-center gap-3">
      <Image src={Logo} alt="Vallax" class="h-9 w-auto" />
    </a>

    <div
      class="hidden lg:flex items-center gap-6 text-xs uppercase tracking-[0.3em] text-white/60"
    >
      {
        links.map((link) => (
          <a
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noreferrer" : undefined}
            class={`transition-colors ${link.external ? "hover:text-primary" : "hover:text-white"}`}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={t.languageSwitcher.href}
        hreflang={t.languageSwitcher.target}
        class="text-white/50 transition-colors hover:text-white"
      >
        {t.languageSwitcher.shortLabel}
      </a>
    </div>

    <div class="hidden lg:block">
      <a
        onclick="trackClick('nav-desktop-primary')"
        href="https://t.me/vallaxbot"
        target="_blank"
        class="btn btn-primary px-[22px] py-[14px] group"
      >
        <span class="text-[#07D9C4] text-[24px] font-semibold leading-[20px]"
          >/</span
        >
        <span class="text-[#07D9C4] text-base font-bold leading-[20px]"
          >{t.primaryCta}</span
        >
        <CornerBorders color="#07D9C4" />
      </a>
    </div>

    <button
      id="mobile-menu-toggle"
      aria-label="Toggle menu"
      class="flex h-10 w-10 items-center justify-center border border-white/20 bg-black/50 lg:hidden"
    >
      <span class="sr-only">Toggle navigation</span>
      <div class="space-y-[6px]">
        <span class="block h-0.5 w-6 bg-white transition-transform duration-200"
        ></span>
        <span class="block h-0.5 w-6 bg-white transition-opacity duration-200"
        ></span>
        <span class="block h-0.5 w-6 bg-white transition-transform duration-200"
        ></span>
      </div>
    </button>
  </div>

  <div id="mobile-menu-overlay" class="fixed inset-0 z-40 hidden bg-black/80">
  </div>

  <div id="mobile-menu" class="fixed inset-x-0 top-[72px] z-50 hidden px-[3%]">
    <div
      class="relative border border-white/15 bg-black/95 px-6 py-7 text-xs uppercase tracking-[0.3em] text-white/75"
    >
      <CornerBorders color="#07D9C4" />
      {
        links.map((link) => (
          <a
            onclick="window.closeMobileMenu()"
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noreferrer" : undefined}
            class={`block py-3 ${link.external ? "text-primary" : ""}`}
          >
            {link.label}
          </a>
        ))
      }
      <a
        onclick="window.closeMobileMenu()"
        href={t.languageSwitcher.href}
        hreflang={t.languageSwitcher.target}
        class="block py-3 text-white/50"
      >
        {t.languageSwitcher.label}
      </a>
      <a
        onclick="window.closeMobileMenu(); trackClick('nav-mobile-primary')"
        href="https://t.me/vallaxbot"
        target="_blank"
        class="mt-4 inline-flex items-center gap-2 border border-primary/40 px-4 py-2 text-primary"
      >
        <span>/</span>
        {t.primaryCta}
      </a>
    </div>
  </div>
</nav>
