---
import type { Translation } from "../../i18n";

interface Props {
  t: Translation["footer"];
}

const { t } = Astro.props as Props;
---

<footer class="mt-24 border-t border-white/10 bg-black/30 backdrop-blur-sm">
  <div class="max-w-[1728px] mx-auto px-[3%] lg:px-[5%] py-12 grid gap-10 lg:grid-cols-[2fr_1fr]">
    <div class="space-y-6">
      <h2 class="text-[24px] leading-[30px] font-bold">{t.headline}</h2>
      <p class="text-sm leading-6 text-white/60 max-w-[560px]">{t.description}</p>

      <div class="flex flex-wrap gap-4 text-xs uppercase tracking-[0.25em] text-white/50">
        {t.marketplaces.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noreferrer"
            class="hover:text-white transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <div class="space-y-4 text-sm leading-6 text-white/60">
      <h3 class="text-white font-semibold uppercase tracking-[0.35em] text-xs">{t.contactTitle}</h3>
      <a
        href={`mailto:${t.contactEmailLabel}`}
        class="inline-block text-white hover:text-primary transition-colors"
      >
        {t.contactEmailLabel}
      </a>
      <div class="flex gap-4 pt-2">
        {t.socials.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noreferrer"
            class="text-white/50 hover:text-white transition-colors text-xs uppercase tracking-[0.25em]"
          >
            {social.label}
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="border-t border-white/10 py-6 text-center text-xs uppercase tracking-[0.25em] text-white/50">
    {t.rights}
  </div>
</footer>
