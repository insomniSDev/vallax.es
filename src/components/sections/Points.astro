---
import PlusIcon from "../icons/PlusIcon.astro";
import CornerBorders from "../ui/CornerBorders.astro";
import type { Translation } from "../../i18n";

interface Props {
  t: Translation["points"];
}

const { t } = Astro.props as Props;
---

<section class="mt-28 md:mt-36" id="features">
  <div class="max-w-[1728px] mx-auto px-[3%] lg:px-[5%]">
    <div class="text-center max-w-[760px] mx-auto space-y-4">
      <span class="text-xs font-semibold uppercase tracking-[0.35em] text-white/60">
        {t.badge}
      </span>
      <h2 class="text-[30px] leading-[38px] font-bold md:text-[40px] md:leading-[48px]">
        {t.title}
      </h2>
      <p class="text-sm leading-6 text-white/60">{t.description}</p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {t.features.map((feature) => (
        <article class="relative border border-white/10 bg-white/[0.04] px-6 py-7 text-left" key={feature.title}>
          <CornerBorders color="#07D9C4" />
          <div class="flex items-center gap-3 text-primary uppercase tracking-[0.25em] text-xs">
            <PlusIcon size={14} stroke="#07D9C4" opacity={1} strokeWidth={1.5} />
            Vallax
          </div>
          <h3 class="mt-4 text-lg font-semibold text-white">{feature.title}</h3>
          <p class="mt-3 text-sm leading-6 text-white/65">{feature.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
