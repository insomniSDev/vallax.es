---
const { content } = Astro.props;
---

<div
  class="flex py-2 px-2 mx-6 border items-center bg-bg/40 border-white/15 rounded-[25px] gap-4 backdrop-blur-xs"
>
  <img src="/assets/images/telegram-rounded.png" />
  <div class="flex flex-col">
    <span class="text-[10px] opacity-50">Vallax Noti</span>
    <span class="text-[14px]">{content}</span>
  </div>
</div>
