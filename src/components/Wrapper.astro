---
import RadialGlow from "./RadialGlow.astro";

import Header from "./sections/Header.astro";
import About from "./sections/About.astro";
import Community from "./sections/Community.astro";
import Footer from "./sections/Footer.astro";
import Navbar from "./sections/Navbar.astro";
import Platforms from "./sections/Platforms.astro";
import Points from "./sections/Points.astro";
import HowToStart from "./sections/HowToStart.astro";

import type { Locale, Translation } from "../i18n";

interface Props {
  lang: Locale;
  t: Translation;
}

const { lang, t } = Astro.props as Props;
---

<div class="flex flex-col items-center overflow-x-hidden">
  <Navbar lang={lang} t={t.navbar} />
  <main class="flex flex-col items-center w-full pt-[120px] md:pt-[140px]">
    <Header t={t.hero} />
    <Platforms t={t.platforms} />

    <div class="max-w-[1728px] w-full">
      <div class="px-[3%] lg:px-[5%] relative">
        <About t={t.about} />
        <Points t={t.points} />
        <HowToStart t={t.howToStart} />
        <Community t={t.community} />
      </div>
    </div>
  </main>
</div>

<Footer t={t.footer} />
